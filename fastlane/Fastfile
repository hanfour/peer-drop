default_platform(:ios)

platform :ios do
  desc "Capture App Store screenshots"
  lane :screenshots do
    capture_screenshots(
      scheme: "PeerDropUITests",
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true,
      override_status_bar: true,
      localize_simulator: true,
      reinstall_app: false,
      erase_simulator: false,
      headless: true,
      derived_data_path: "./fastlane/derived_data"
    )
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    upload_to_app_store(
      skip_binary_upload: true,
      skip_metadata: true,
      screenshots_path: "./fastlane/screenshots",
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Capture screenshots and upload to App Store Connect"
  lane :screenshots_and_upload do
    screenshots
    upload_screenshots
  end

  desc "Add device frames and titles to screenshots (frameit - requires supported devices)"
  lane :add_frames_frameit do
    frame_screenshots(
      path: "./fastlane/screenshots",
      white: false,
      force_device_type: nil
    )
  end

  desc "Add background and titles to screenshots (custom script - works with all devices)"
  lane :add_frames do
    sh("python3 ../fastlane/frame_screenshots.py ../fastlane/screenshots")
  end

  desc "Capture screenshots and add frames"
  lane :screenshots_framed do
    screenshots
    add_frames
  end

  desc "Download existing metadata from App Store Connect"
  lane :download_metadata do
    download_metadata(
      path: "./fastlane/metadata"
    )
  end

  desc "Upload metadata to App Store Connect"
  desc "Pass version: parameter (e.g. `fastlane upload_metadata version:4.0.0`)"
  desc "if the target version doesn't exist on ASC yet (otherwise omit and"
  desc "fastlane uses whatever's currently editable)."
  lane :upload_metadata do |options|
    upload_to_app_store(
      api_key_path: "./fastlane/api_key.json",
      app_version: options[:version],
      skip_binary_upload: true,
      skip_screenshots: true,
      metadata_path: "./fastlane/metadata",
      precheck_include_in_app_purchases: false,
      force: true
    )
  end

  # -------------------------------------------------------------------------
  # Diagnostics — read-only ASC queries.
  # -------------------------------------------------------------------------

  desc "Print ASC review status: live + in-flight versions + recent builds"
  lane :check_status do
    require "spaceship"
    require "json"

    api_key_path = File.expand_path("api_key.json", __dir__)
    UI.user_error!("API key not found at #{api_key_path}") unless File.exist?(api_key_path)

    # fastlane's app_store_connect_api_key action doesn't accept JSON dumps
    # directly, so destructure and feed the fields. set_spaceship_token
    # defaults to true → Spaceship is auth'd after this call.
    data = JSON.parse(File.read(api_key_path))
    app_store_connect_api_key(
      key_id:      data["key_id"],
      issuer_id:   data["issuer_id"],
      key_content: data["key"],
      duration:    data["duration"] || 1200,
      in_house:    data["in_house"] || false
    )

    bundle_id = "com.hanfour.peerdrop"
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    UI.user_error!("App not found: #{bundle_id}") unless app

    UI.success("App: #{app.name} (#{bundle_id}) — id #{app.id}")
    UI.message("")

    live = app.get_live_app_store_version
    if live
      UI.success("=== Live (on App Store) ===")
      UI.message("  v#{live.version_string} — #{live.app_store_state}")
      UI.message("  Released: #{live.created_date}")
      UI.message("")
    end

    edit = app.get_edit_app_store_version
    if edit
      UI.success("=== In Flight (draft / in review / rejected) ===")
      UI.message("  v#{edit.version_string} — #{edit.app_store_state}")
      UI.message("  Release type: #{edit.release_type}")
      UI.message("  Created:      #{edit.created_date}")
      if (b = edit.build)
        UI.message("  Build:        #{b.version} (uploaded #{b.uploaded_date})")
      end
      UI.message("")
    else
      UI.message("(no edit version — nothing in flight)")
      UI.message("")
    end

    recent = app.get_app_store_versions(limit: 10)
    if recent.any?
      UI.success("=== Recent Versions ===")
      recent.each do |v|
        UI.message("  v#{v.version_string.ljust(8)} #{v.app_store_state.to_s.ljust(28)} #{v.created_date}")
      end
      UI.message("")
    end

    builds = app.get_builds(limit: 5, includes: "preReleaseVersion")
    if builds.any?
      UI.success("=== Recent Builds (TestFlight) ===")
      builds.each do |b|
        v = b.pre_release_version&.version || "?"
        UI.message("  build #{b.version.to_s.ljust(4)} → v#{v.ljust(8)} #{b.processing_state.to_s.ljust(12)} uploaded #{b.uploaded_date}")
      end
    end
  end

  desc "TEMP DIAG: list every iOS App Store version (any state, any platform)"
  lane :diag_versions do
    require "spaceship"
    require "json"
    api_key_path = File.expand_path("api_key.json", __dir__)
    data = JSON.parse(File.read(api_key_path))
    app_store_connect_api_key(
      key_id:      data["key_id"],
      issuer_id:   data["issuer_id"],
      key_content: data["key"],
      duration:    data["duration"] || 1200,
      in_house:    data["in_house"] || false
    )
    app = Spaceship::ConnectAPI::App.find("com.hanfour.peerdrop")
    UI.message("All iOS versions (unfiltered):")
    versions = app.get_app_store_versions(limit: 200)
    versions.each do |v|
      UI.message("  v#{v.version_string.ljust(8)} #{v.platform.to_s.ljust(8)} #{v.app_store_state.to_s.ljust(28)} #{v.created_date}")
    end
    UI.message("")
    UI.message("All iOS builds (last 20):")
    builds = app.get_builds(limit: 20, includes: "preReleaseVersion")
    builds.each do |b|
      v = b.pre_release_version&.version || "?"
      UI.message("  build #{b.version.to_s.ljust(4)} → v#{v.ljust(8)} #{b.processing_state.to_s.ljust(12)} expired=#{b.expired} uploaded #{b.uploaded_date}")
    end
  end

  desc "Poll ASC for state changes; alert via macOS Notification + iMessage + log"
  desc "Notifies on: edit-version state change, build processing-state change,"
  desc "live-version replacement (a release went out)."
  desc "State persisted in .asc-monitor-state.json (gitignored)."
  desc "Run via: while true; do fastlane monitor; sleep 3600; done"
  lane :monitor do
    require "spaceship"
    require "json"
    require "time"

    bundle_id    = "com.hanfour.peerdrop"
    state_file   = File.expand_path("../.asc-monitor-state.json", __dir__)
    log_file     = File.expand_path("monitor.log", __dir__)
    imessage_to  = ["+886972995958", "hanfour.huang@icloud.com"]

    # Auth
    api_key_path = File.expand_path("api_key.json", __dir__)
    UI.user_error!("API key not found at #{api_key_path}") unless File.exist?(api_key_path)
    data = JSON.parse(File.read(api_key_path))
    app_store_connect_api_key(
      key_id:      data["key_id"],
      issuer_id:   data["issuer_id"],
      key_content: data["key"],
      duration:    data["duration"] || 1200,
      in_house:    data["in_house"] || false
    )

    log = ->(msg) {
      line = "[#{Time.now.iso8601}] #{msg}"
      File.open(log_file, "a") { |f| f.puts line }
      UI.message(line)
    }

    notify_macos = ->(title, msg) {
      esc = ->(s) { s.to_s.gsub("\\", "\\\\").gsub('"', '\\"') }
      system("osascript", "-e", %(display notification "#{esc.(msg)}" with title "#{esc.(title)}" sound name "Glass"))
    }

    notify_imessage = ->(text) {
      imessage_to.each do |addr|
        # Escape AppleScript string literal
        msg = text.to_s.gsub("\\", "\\\\").gsub('"', '\\"').gsub("\n", "\\n")
        script = %(
          tell application "Messages"
            set targetService to 1st service whose service type = iMessage
            set targetBuddy to buddy "#{addr}" of targetService
            send "#{msg}" to targetBuddy
          end tell
        )
        system("osascript", "-e", script)
      end
    }

    alert = ->(title, body) {
      log.("ALERT #{title} — #{body}")
      notify_macos.(title, body)
      notify_imessage.("PeerDrop ASC: #{title}\n#{body}")
    }

    # Snapshot current state
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    UI.user_error!("App not found: #{bundle_id}") unless app

    edit = app.get_edit_app_store_version
    live = app.get_live_app_store_version
    builds = app.get_builds(limit: 5, includes: "preReleaseVersion")

    snapshot = {
      checked_at: Time.now.iso8601,
      edit_version: edit&.version_string,
      edit_state:   edit&.app_store_state,
      edit_release: edit&.release_type,
      edit_build:   edit&.build&.version,
      live_version: live&.version_string,
      live_state:   live&.app_store_state,
      builds: builds.map { |b|
        {
          version: b.version,
          ver_str: b.pre_release_version&.version,
          processing_state: b.processing_state.to_s,
        }
      }
    }

    # Compare to previous
    if File.exist?(state_file)
      prev = JSON.parse(File.read(state_file))

      if prev["edit_state"] != snapshot[:edit_state]
        # When edit version disappears (nil), it's because the version was
        # approved + released and is now live-only. Use prev's data for
        # context since current snapshot's edit fields are all nil.
        if snapshot[:edit_state].nil? && prev["edit_state"]
          alert.(
            "v#{prev["edit_version"]} approved & released",
            "Was #{prev["edit_state"]}; now off the edit-version list (likely live)"
          )
        elsif snapshot[:edit_state] && prev["edit_state"].nil?
          alert.(
            "New edit version: v#{snapshot[:edit_version]} — #{snapshot[:edit_state]}",
            "release type=#{snapshot[:edit_release] || '?'}; build #{snapshot[:edit_build] || '(none)'}"
          )
        else
          alert.(
            "v#{snapshot[:edit_version]} → #{snapshot[:edit_state]}",
            "was #{prev["edit_state"]}; release type=#{snapshot[:edit_release] || '?'}; build #{snapshot[:edit_build] || '(none)'}"
          )
        end
      end

      if prev["live_version"] != snapshot[:live_version]
        alert.(
          "Live version changed",
          "#{prev["live_version"]} → #{snapshot[:live_version]} (#{snapshot[:live_state]})"
        )
      end

      # Build processing state changes
      prev_builds = (prev["builds"] || []).each_with_object({}) { |b, h| h[[b["version"], b["ver_str"]]] = b["processing_state"] }
      snapshot[:builds].each do |b|
        key = [b[:version], b[:ver_str]]
        old_state = prev_builds[key]
        if old_state && old_state != b[:processing_state]
          alert.(
            "Build #{b[:version]} (v#{b[:ver_str]}) → #{b[:processing_state]}",
            "was #{old_state}"
          )
        end
      end

      log.("STABLE edit=#{snapshot[:edit_state]} live=#{snapshot[:live_version]}") if prev["edit_state"] == snapshot[:edit_state] && prev["live_version"] == snapshot[:live_version]
    else
      log.("INIT edit=v#{snapshot[:edit_version]}/#{snapshot[:edit_state]} live=v#{snapshot[:live_version]}")
      notify_macos.("PeerDrop monitor started", "Tracking v#{snapshot[:edit_version]} (#{snapshot[:edit_state]})")
    end

    File.write(state_file, JSON.pretty_generate(snapshot))
  end

  # -------------------------------------------------------------------------
  # Release lanes — build archive + upload to App Store Connect.
  # Uses api_key.json for non-interactive authentication.
  # -------------------------------------------------------------------------

  desc "Build Release archive (no upload) — useful for inspection"
  lane :build do
    build_app(
      scheme: "PeerDrop",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./fastlane/build",
      output_name: "PeerDrop.ipa",
      clean: true,
      include_bitcode: false,
      include_symbols: true
    )
  end

  desc "Build and upload to TestFlight (no review submission)"
  lane :beta do
    build_app(
      scheme: "PeerDrop",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./fastlane/build",
      output_name: "PeerDrop.ipa",
      clean: true,
      include_bitcode: false,
      include_symbols: true,
      # Xcode 16+ moved profiles to ~/Library/Developer/Xcode/UserData/...
      # gym's auto-generated exportOptions doesn't find them; pin the
      # profile names explicitly so xcodebuild -exportArchive succeeds
      # without needing -allowProvisioningUpdates.
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "UK48R5KWLV",
        provisioningProfiles: {
          "com.hanfour.peerdrop" => "com.hanfour.peerdrop AppStore",
          "com.hanfour.peerdrop.widget" => "com.hanfour.peerdrop.widget AppStore"
        }
      }
    )
    upload_to_testflight(
      api_key_path: "./fastlane/api_key.json",
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      notify_external_testers: false,
      changelog: ENV["PEERDROP_CHANGELOG"] || "Internal build."
    )
  end

  desc "Build and submit to App Store review (auto-release on approval)"
  desc "Auto-loads reviewer notes (same as submit_only). Default phased:false."
  desc "Pass submit:false to upload only (e.g. to attach IAPs in ASC before submit)."
  lane :release do |options|
    # Load the ASC API key into the lane context BEFORE build_app so
    # gym can forward `-authenticationKey*` flags to xcodebuild — this
    # is what lets `-allowProvisioningUpdates` actually refresh the
    # team auto-profile when an App ID gains a new capability (v5.3's
    # Push Notifications was the first case to hit this path).
    api_key_path = File.expand_path("api_key.json", __dir__)
    UI.user_error!("API key not found at #{api_key_path}") unless File.exist?(api_key_path)
    data = JSON.parse(File.read(api_key_path))
    app_store_connect_api_key(
      key_id:      data["key_id"],
      issuer_id:   data["issuer_id"],
      key_content: data["key"],
      duration:    1200,
      in_house:    false
    )

    # Auto-load reviewer notes from docs/release/v<version>-reviewer-notes.md.
    # Derived from project's MARKETING_VERSION so hotfix releases pick up
    # their own notes file (e.g. v4.0.1-reviewer-notes.md).
    version_match = File.read(File.expand_path("../project.yml", __dir__)).match(/MARKETING_VERSION:\s*"([^"]+)"/)
    version = version_match ? version_match[1] : nil
    UI.message("Detected MARKETING_VERSION: #{version || '(unknown)'}")

    review_info = nil
    if version
      major_minor = version[/^\d+\.\d+/]
      versioned_path = File.expand_path("../docs/release/v#{version}-reviewer-notes.md", __dir__)
      base_path      = File.expand_path("../docs/release/v#{major_minor}-reviewer-notes.md", __dir__)
      notes_path     = File.exist?(versioned_path) ? versioned_path : base_path
      if File.exist?(notes_path)
        raw   = File.read(notes_path)
        match = raw.match(/<!-- BEGIN_PASTE.*?-->(.*?)<!-- END_PASTE -->/m)
        if match
          notes = match[1].gsub(/^#+\s*/, "").strip
          UI.message("Reviewer notes loaded: #{notes.length} chars from #{File.basename(notes_path)}")
          UI.important("ASC notes field limit is ~4000 chars — content may truncate") if notes.length > 4000
          review_info = { notes: notes }
        else
          UI.important("Reviewer notes file found but BEGIN_PASTE/END_PASTE markers missing: #{notes_path}")
        end
      else
        UI.important("No reviewer notes file at #{versioned_path} or #{base_path} — submitting without")
      end
    end

    # `-allowProvisioningUpdates` lets xcodebuild refresh the team
    # auto-profile when the App ID's capabilities change (e.g. v5.3's
    # Push Notifications add). gym doesn't auto-forward the ASC key to
    # xcodebuild for this, so write the key to a temp .p8 and pass the
    # three -authenticationKey* args explicitly. Cleaned up below.
    asc_key_p8 = "/tmp/asc-api-key-#{Process.pid}.p8"
    File.write(asc_key_p8, data["key"])
    File.chmod(0o600, asc_key_p8)
    auth_xcargs = "-allowProvisioningUpdates " \
                  "-authenticationKeyID #{data['key_id']} " \
                  "-authenticationKeyIssuerID #{data['issuer_id']} " \
                  "-authenticationKeyPath #{asc_key_p8}"

    build_app(
      scheme: "PeerDrop",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./fastlane/build",
      output_name: "PeerDrop.ipa",
      clean: true,
      include_bitcode: false,
      include_symbols: true,
      xcargs: auth_xcargs,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.hanfour.peerdrop" => "com.hanfour.peerdrop AppStore",
          "com.hanfour.peerdrop.widget" => "com.hanfour.peerdrop.widget AppStore"
        }
      }
    )
    File.delete(asc_key_p8) if File.exist?(asc_key_p8)

    # `submit: false` lets the operator pause between upload and submit —
    # currently used to manually attach In-App Purchases via the ASC web
    # UI (Spaceship has no IAP-attach API and the deliver action has no
    # `in_app_purchases` parameter). After upload completes, version
    # sits in PREPARE_FOR_SUBMISSION and the ASC web UI exposes the
    # "App 內購買項目和訂閱項目" section. Submit via `fastlane submit_only`
    # once IAPs are attached.
    should_submit = options.fetch(:submit, true)
    upload_to_app_store(
      api_key_path: "./fastlane/api_key.json",
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata",
      # `fastlane/metadata/macos/` holds the Mac (v6.0) App Store metadata
      # (added in the M4 work). iOS `deliver` scans the whole metadata dir and
      # rejects `macos` as an unknown language code — this flag tells it to skip
      # unrecognised dirs instead of erroring. Only valid iOS locale dirs upload.
      ignore_language_directory_validation: true,
      submit_for_review: should_submit,
      automatic_release: should_submit,
      phased_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      app_review_information: review_info,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true
      }
    )
  end

  desc "Submit an already-uploaded TestFlight build for review (no rebuild)"
  desc "Defaults: phased rollout + manual release — safe for major versions."
  desc "Auto-loads reviewer notes from docs/release/v<version>-reviewer-notes.md (falls back to v<major.minor>)."
  desc "Release the current PENDING_DEVELOPER_RELEASE version to App Store."
  desc "Use after an approved version was submitted without auto-release"
  desc "(e.g. `fastlane release submit:false` followed by manual ASC submit)."
  lane :release_now do
    api_key_path = File.expand_path("api_key.json", __dir__)
    UI.user_error!("API key not found at #{api_key_path}") unless File.exist?(api_key_path)
    data = JSON.parse(File.read(api_key_path))
    app_store_connect_api_key(
      key_id:      data["key_id"],
      issuer_id:   data["issuer_id"],
      key_content: data["key"],
      duration:    1200,
      in_house:    false
    )

    app_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier) || "com.hanfour.peerdrop"
    app = Spaceship::ConnectAPI::App.find(app_id)
    UI.user_error!("App not found for bundle id #{app_id}") unless app

    pending = app.get_app_store_versions(
      filter: { appStoreState: "PENDING_DEVELOPER_RELEASE" }
    ).first
    UI.user_error!("No PENDING_DEVELOPER_RELEASE version found.") unless pending

    UI.message("Releasing v#{pending.version_string} (id #{pending.id})...")
    pending.create_app_store_version_release_request
    UI.success("✓ Release request created for v#{pending.version_string}. App Store will roll it out within minutes.")
  end

  desc "Args: version:X.Y.Z build:N [auto_release:true] [phased:false] [no_review_notes:true]"
  desc "Example: fastlane submit_only version:4.0.0 build:1"
  lane :submit_only do |options|
    # Default both ON (safer for major versions). Override with
    # `phased:false` for instant 100% rollout, `auto_release:true`
    # to skip the "Pending Developer Release" gate.
    phased_release    = options[:phased] != "false"
    automatic_release = options[:auto_release] == "true"

    UI.message("Submission strategy: phased=#{phased_release}, automatic=#{automatic_release}")

    review_info = nil
    unless options[:no_review_notes] == "true"
      version = options[:version]
      UI.user_error!("version: required when auto-loading reviewer notes (or pass no_review_notes:true)") unless version

      major_minor = version[/^\d+\.\d+/]
      UI.user_error!("Could not parse major.minor from version '#{version}'") unless major_minor

      # Prefer patch-version-specific notes (v4.0.1-...) when present, else
      # fall back to major.minor notes (v4.0-...). Lets hotfixes ship their
      # own reviewer notes without overwriting the parent release's file.
      versioned_path  = File.expand_path("../docs/release/v#{version}-reviewer-notes.md", __dir__)
      base_path       = File.expand_path("../docs/release/v#{major_minor}-reviewer-notes.md", __dir__)
      notes_path      = File.exist?(versioned_path) ? versioned_path : base_path
      UI.user_error!("Reviewer notes not found: tried #{versioned_path} and #{base_path}") unless File.exist?(notes_path)

      raw = File.read(notes_path)
      match = raw.match(/<!-- BEGIN_PASTE.*?-->(.*?)<!-- END_PASTE -->/m)
      UI.user_error!("BEGIN_PASTE / END_PASTE markers not found in #{notes_path}") unless match

      notes = match[1].gsub(/^#+\s*/, "").strip
      UI.message("Reviewer notes loaded: #{notes.length} chars from #{File.basename(notes_path)}")
      UI.important("ASC notes field limit is ~4000 chars — content may truncate") if notes.length > 4000
      review_info = { notes: notes }
    end

    upload_to_app_store(
      api_key_path: "./fastlane/api_key.json",
      app_version: options[:version],
      build_number: options[:build],
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata",
      submit_for_review: true,
      automatic_release: automatic_release,
      phased_release: phased_release,
      force: true,
      precheck_include_in_app_purchases: false,
      app_review_information: review_info,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true
      }
    )
  end

  # ============================================================================
  # M4 — Mac App Store lanes (v6.0.0+)
  # ============================================================================
  # Mirrors of the iOS release / check_status / submit_only lanes targeted at
  # the macOS platform (PeerDropMac scheme, com.hanfour.peerdrop.mac bundle).
  # Spaceship's macOS query path uses Platform::MAC_OS; deliver's takes
  # `platform: "osx"`. Reviewer notes auto-load from the same
  # docs/release/v<version>-reviewer-notes.md file shared with iOS — both
  # platforms ship the same version per spec §M4.

  desc "Capture Mac App Store screenshots via PeerDropMacUITests"
  desc "Output: ./fastlane/screenshots_mac/<lang>/*.png"
  desc "macOS uses the host's screen resolution (no simulator); capture at"
  desc "highest available DPI and downsample post-hoc for the smaller ASC"
  desc "size brackets if needed."
  lane :screenshots_mac do
    capture_mac_screenshots(
      scheme: "PeerDropMacUITests",
      output_directory: "./fastlane/screenshots_mac",
      languages: ["en-US", "zh-Hant", "zh-Hans", "ja", "ko"],
      launch_arguments: ["-SCREENSHOT_MODE 1"],
      clear_previous_screenshots: true,
      only_testing: [
        "PeerDropMacUITests/MacSnapshotTests",
        "PeerDropMacUITests/MacSnapshotTestsDark"
      ]
    )
  end

  desc "Print ASC review status for the Mac App: live + in-flight versions"
  lane :check_status_mac do
    require "spaceship"
    require "json"

    api_key_path = File.expand_path("api_key.json", __dir__)
    UI.user_error!("API key not found at #{api_key_path}") unless File.exist?(api_key_path)
    data = JSON.parse(File.read(api_key_path))
    app_store_connect_api_key(
      key_id:      data["key_id"],
      issuer_id:   data["issuer_id"],
      key_content: data["key"],
      duration:    data["duration"] || 1200,
      in_house:    data["in_house"] || false
    )

    # The Mac bundle shares the App record with iOS (PRODUCT_BUNDLE_IDENTIFIER
    # com.hanfour.peerdrop on iOS, com.hanfour.peerdrop.mac on macOS) — both
    # roll up to the same Spaceship::ConnectAPI::App via Apple ID 6759594513.
    # Pass `platform: MAC_OS` to filter the version queries.
    bundle_id = "com.hanfour.peerdrop.mac"
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    UI.user_error!("Mac app not found: #{bundle_id} — has ASC macOS platform been enabled? See M4 plan Task 4.") unless app

    mac_platform = Spaceship::ConnectAPI::Platform::MAC_OS
    UI.success("App: #{app.name} (#{bundle_id}) — id #{app.id}")
    UI.message("")

    live = app.get_live_app_store_version(platform: mac_platform)
    if live
      UI.success("=== Live (on Mac App Store) ===")
      UI.message("  v#{live.version_string} — #{live.app_store_state}")
      UI.message("  Released: #{live.created_date}")
      UI.message("")
    else
      UI.message("(no live Mac version yet)")
      UI.message("")
    end

    edit = app.get_edit_app_store_version(platform: mac_platform)
    if edit
      UI.success("=== In Flight (draft / in review / rejected) ===")
      UI.message("  v#{edit.version_string} — #{edit.app_store_state}")
      UI.message("  Release type: #{edit.release_type}")
      UI.message("  Created:      #{edit.created_date}")
      if (b = edit.build)
        UI.message("  Build:        #{b.version} (uploaded #{b.uploaded_date})")
      end
      UI.message("")
    else
      UI.message("(no edit Mac version — nothing in flight)")
      UI.message("")
    end

    recent = app.get_app_store_versions(filter: { platform: mac_platform }, limit: 10)
    if recent.any?
      UI.success("=== Recent Mac Versions ===")
      recent.each do |v|
        UI.message("  v#{v.version_string.ljust(8)} #{v.app_store_state.to_s.ljust(28)} #{v.created_date}")
      end
    end
  end

  desc "Build + upload Mac binary to App Store (and submit unless submit:false)"
  desc "Auto-loads reviewer notes from docs/release/v<version>-reviewer-notes.md."
  desc "Default behavior: submit:true automatically (matches iOS release lane);"
  desc "pass submit:false to leave v6.0.0 in PREPARE_FOR_SUBMISSION so the IAP"
  desc "tip jar can be attached via Playwright before submission."
  lane :release_mac do |options|
    # Same ASC API key auth + reviewer-notes load + temp .p8 dance as the iOS
    # release lane. Centralising would be cleaner; kept inline for parity.
    api_key_path = File.expand_path("api_key.json", __dir__)
    UI.user_error!("API key not found at #{api_key_path}") unless File.exist?(api_key_path)
    data = JSON.parse(File.read(api_key_path))
    app_store_connect_api_key(
      key_id:      data["key_id"],
      issuer_id:   data["issuer_id"],
      key_content: data["key"],
      duration:    1200,
      in_house:    false
    )

    # Auto-load reviewer notes from the SAME file iOS uses — both platforms
    # ship the same version v6.0.0 per spec §M4.
    version_match = File.read(File.expand_path("../project.yml", __dir__)).match(/MARKETING_VERSION:\s*"([^"]+)"/)
    version = version_match ? version_match[1] : nil
    UI.message("Detected MARKETING_VERSION: #{version || '(unknown)'}")

    review_info = nil
    if version
      major_minor = version[/^\d+\.\d+/]
      versioned_path = File.expand_path("../docs/release/v#{version}-reviewer-notes.md", __dir__)
      base_path      = File.expand_path("../docs/release/v#{major_minor}-reviewer-notes.md", __dir__)
      notes_path     = File.exist?(versioned_path) ? versioned_path : base_path
      if File.exist?(notes_path)
        raw   = File.read(notes_path)
        match = raw.match(/<!-- BEGIN_PASTE.*?-->(.*?)<!-- END_PASTE -->/m)
        if match
          notes = match[1].gsub(/^#+\s*/, "").strip
          UI.message("Reviewer notes loaded: #{notes.length} chars from #{File.basename(notes_path)}")
          UI.important("ASC notes field limit is ~4000 chars — content may truncate") if notes.length > 4000
          review_info = { notes: notes }
        else
          UI.important("Reviewer notes file found but BEGIN_PASTE/END_PASTE markers missing: #{notes_path}")
        end
      else
        UI.important("No reviewer notes file at #{versioned_path} or #{base_path} — submitting without")
      end
    end

    asc_key_p8 = "/tmp/asc-api-key-mac-#{Process.pid}.p8"
    File.write(asc_key_p8, data["key"])
    File.chmod(0o600, asc_key_p8)
    auth_xcargs = "-allowProvisioningUpdates " \
                  "-authenticationKeyID #{data['key_id']} " \
                  "-authenticationKeyIssuerID #{data['issuer_id']} " \
                  "-authenticationKeyPath #{asc_key_p8}"

    # Mac archive. PeerDropMac has no widget extension (vs iOS), so
    # provisioningProfiles is a single entry. The profile name is the
    # ASC-default "<bundle_id> AppStore" — `fastlane run get_provisioning_profile`
    # in M4 Task 3 creates and downloads it.
    build_app(
      scheme: "PeerDropMac",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./fastlane/build",
      output_name: "PeerDrop-Mac.pkg",
      clean: true,
      include_bitcode: false,
      include_symbols: true,
      xcargs: auth_xcargs,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.hanfour.peerdrop.mac" => "com.hanfour.peerdrop.mac AppStore"
        }
      }
    )
    File.delete(asc_key_p8) if File.exist?(asc_key_p8)

    # `submit: false` leaves v6.0.0 in PREPARE_FOR_SUBMISSION so the Mac
    # IAP tip jar can be attached via the M4 Task 10 Playwright flow
    # (ASC has no API for attaching IAPs; web UI only). After attach,
    # call `submit_mac_only` to ship.
    #
    # precheck_include_in_app_purchases: false matches iOS — IAP screenshot
    # quirks tracked in feedback-asc-iap-quirks make precheck noisy.
    should_submit = options.fetch(:submit, true)
    upload_to_app_store(
      api_key_path: "./fastlane/api_key.json",
      platform: "osx",
      skip_screenshots: false,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata/macos",
      screenshots_path: "./fastlane/screenshots_mac",
      submit_for_review: should_submit,
      automatic_release: should_submit,
      phased_release: false,  # first Mac ship — manual release per M4 plan Task 11
      force: true,
      precheck_include_in_app_purchases: false,
      app_review_information: review_info,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true
      }
    )
  end

  desc "Submit an already-uploaded Mac TestFlight build for review (no rebuild)"
  desc "Args: version:X.Y.Z build:N [auto_release:true] [phased:false] [no_review_notes:true]"
  desc "Example: fastlane submit_mac_only version:6.0.0 build:1"
  desc "Use after `release_mac submit:false` + Playwright IAP attach."
  lane :submit_mac_only do |options|
    # phased_release defaults to false for the first Mac ship — see M4 plan
    # Task 11 (sandbox surprises only surface in shipped builds; we want
    # full rollback control, not a partial-user-base exposure window).
    # v6.1+ can default to phased.
    phased_release    = options[:phased] == "true"
    automatic_release = options[:auto_release] == "true"

    UI.message("Mac submission strategy: phased=#{phased_release}, automatic=#{automatic_release}")

    review_info = nil
    unless options[:no_review_notes] == "true"
      version = options[:version]
      UI.user_error!("version: required when auto-loading reviewer notes (or pass no_review_notes:true)") unless version

      major_minor = version[/^\d+\.\d+/]
      UI.user_error!("Could not parse major.minor from version '#{version}'") unless major_minor

      versioned_path  = File.expand_path("../docs/release/v#{version}-reviewer-notes.md", __dir__)
      base_path       = File.expand_path("../docs/release/v#{major_minor}-reviewer-notes.md", __dir__)
      notes_path      = File.exist?(versioned_path) ? versioned_path : base_path
      UI.user_error!("Reviewer notes not found: tried #{versioned_path} and #{base_path}") unless File.exist?(notes_path)

      raw = File.read(notes_path)
      match = raw.match(/<!-- BEGIN_PASTE.*?-->(.*?)<!-- END_PASTE -->/m)
      UI.user_error!("BEGIN_PASTE / END_PASTE markers not found in #{notes_path}") unless match

      notes = match[1].gsub(/^#+\s*/, "").strip
      UI.message("Reviewer notes loaded: #{notes.length} chars from #{File.basename(notes_path)}")
      UI.important("ASC notes field limit is ~4000 chars — content may truncate") if notes.length > 4000
      review_info = { notes: notes }
    end

    upload_to_app_store(
      api_key_path: "./fastlane/api_key.json",
      platform: "osx",
      app_version: options[:version],
      build_number: options[:build],
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata/macos",
      submit_for_review: true,
      automatic_release: automatic_release,
      phased_release: phased_release,
      force: true,
      precheck_include_in_app_purchases: false,
      app_review_information: review_info,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true
      }
    )
  end

  desc "Release the current PENDING_DEVELOPER_RELEASE Mac version to App Store."
  desc "Use after an approved Mac version was submitted without auto-release"
  desc "(e.g. `fastlane release_mac submit:false` + IAP attach + submit_mac_only)."
  lane :release_now_mac do
    api_key_path = File.expand_path("api_key.json", __dir__)
    UI.user_error!("API key not found at #{api_key_path}") unless File.exist?(api_key_path)
    data = JSON.parse(File.read(api_key_path))
    app_store_connect_api_key(
      key_id:      data["key_id"],
      issuer_id:   data["issuer_id"],
      key_content: data["key"],
      duration:    1200,
      in_house:    false
    )

    bundle_id = "com.hanfour.peerdrop.mac"
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    UI.user_error!("Mac app not found: #{bundle_id} — has ASC macOS platform been enabled?") unless app

    mac_platform = Spaceship::ConnectAPI::Platform::MAC_OS
    pending = app.get_app_store_versions(
      filter: { appStoreState: "PENDING_DEVELOPER_RELEASE", platform: mac_platform }
    ).first
    UI.user_error!("No PENDING_DEVELOPER_RELEASE Mac version found.") unless pending

    UI.message("Releasing Mac v#{pending.version_string} (id #{pending.id})...")
    pending.create_app_store_version_release_request
    UI.success("✓ Mac release request created for v#{pending.version_string}. App Store will roll it out within minutes.")
  end
end
