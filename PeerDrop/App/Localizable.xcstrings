{
  "sourceLanguage": "en",
  "strings": {
    " ": {
      "comment": "A space character.",
      "isCommentAutoGenerated": true
    },
    "%@": {
      "comment": "A small badge displaying the number of users who have read or received a group message.",
      "isCommentAutoGenerated": true
    },
    "%@ characters": {
      "comment": "A footer displaying the number of characters in the previewed text. The single placeholder is replaced with the actual number of characters.",
      "isCommentAutoGenerated": true
    },
    "%@ connected": {
      "comment": "A text label indicating the number of connected devices. The argument is the number of connected devices.",
      "isCommentAutoGenerated": true
    },
    "%@ connections": {
      "comment": "A label showing the number of times a device has connected to a user's device. The argument is the number of connection events.",
      "isCommentAutoGenerated": true
    },
    "%@ is typing...": {
      "comment": "A label below the typing indicators, indicating that a user is typing. The argument is the name of the user.",
      "isCommentAutoGenerated": true
    },
    "%@ online": {
      "comment": "A label showing how many peers are currently \"online\" with a given peer. The argument is the number of peers that are currently \"online\" with the peer in question.",
      "isCommentAutoGenerated": true
    },
    "%@ total": {
      "comment": "A label displaying the total number of devices in the group.",
      "isCommentAutoGenerated": true
    },
    "%@%%": {
      "comment": "A text label displaying the percentage of a file transfer that has been completed. The value is shown in a monospaced font.",
      "isCommentAutoGenerated": true
    },
    "%@/%@": {
      "comment": "A label showing the number of group members who have received the message, followed by the total number of members.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@/%2$@"
          }
        }
      }
    },
    "%@/%@ connected": {
      "comment": "A text label showing the number of currently connected members in the group, followed by a count of the total number of members.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@/%2$@ connected"
          }
        }
      }
    },
    "%@x%@ -- %@": {
      "comment": "A label displaying the dimensions and file size of an image. The first argument is the width of the image in pixels. The second argument is the height of the image in pixels. The third argument is the file size of the image, formatted as a human-readable string.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@x%2$@ -- %3$@"
          }
        }
      }
    },
    "A free VPN that makes cross-network connect feel like same-network": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "異なるネットワーク間の接続を同じネットワークのようにする無料VPN"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 네트워크 간 연결을 같은 네트워크처럼 만들어주는 무료 VPN"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一款免费 VPN，让跨网络连接如同局域网"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "免費 VPN，讓跨網路連線如同區域網路"
          }
        }
      }
    },
