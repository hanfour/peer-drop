<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>PeerDrop</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <key>NSHumanReadableCopyright</key>
    <string>© 2026 Hanfour Huang. All rights reserved.</string>
    <!-- Mac App Store category. Required for MAS distribution. Matches
         iOS primary_category MZGenre.SocialNetworking. -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.social-networking</string>
    <!-- Asset-catalog AppIcon reference (Xcode 11+). The PeerDrop iOS
         universal AppIcon (1024×1024 source) is bundled into the Mac
         build via project.yml sources; Xcode derives the Mac-sized
         icns at compile time. -->
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>
    <!-- URL scheme for peerdrop:// links from chat / share sheets -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.hanfour.peerdrop.mac.url</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>peerdrop</string>
            </array>
        </dict>
    </array>
    <!-- M3: microphone access for WebRTC voice capture. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>PeerDrop uses your microphone for peer-to-peer voice calls.</string>
    <!-- macOS 14+: required for local network access (mDNS, multicast,
         TCP/UDP on local subnet). Without this, Bonjour discovery + relay
         WebSocket fail silently with NEDoNotSupportPeerToPeer error. -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>PeerDrop uses the local network to discover and connect to nearby devices for file transfer and voice calls.</string>
    <!-- Bonjour service types this app advertises and browses. Without
         this entry, mDNSResponder refuses to resolve our service even
         with the multicast entitlement. -->
    <key>NSBonjourServices</key>
    <array>
        <string>_peerdrop._tcp</string>
    </array>
    <!-- Granted by com.apple.security.bluetooth entitlement but macOS
         still shows a user-facing prompt and requires this description. -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>PeerDrop uses Bluetooth to discover nearby devices for file sharing.</string>
    <!-- Export-compliance declaration. PeerDrop uses only exempt
         cryptography (standard TLS, ECDH, AES-GCM, Signal-style ratchet);
         no custom crypto outside the Apple/OpenSSL toolchain. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!-- Cloudflare Worker auth fallback key. Reused from iOS
         project.yml xcconfig variable. -->
    <key>PeerDropWorkerAPIKey</key>
    <string>$(PEERDROP_WORKER_API_KEY)</string>
    <!-- Public keys that sign the relay's crypto-policy blob. Without
         this, SecurityPolicyStore.bundledKeys is empty and worker-served
         policy upgrades cannot be verified (falls back to bundled default
         policy = legacy/warn, which is shipping safe but stuck). -->
    <key>CryptoPolicyPublicKeys</key>
    <array>
        <string>2Mds2dPO3W7UYqwP32fiee4pIK2BPMzVxBfgAKT1nyk=</string>
    </array>
    <!-- Localizations -->
    <key>CFBundleLocalizations</key>
    <array>
        <string>en</string>
        <string>zh-Hant</string>
        <string>zh-Hans</string>
        <string>ja</string>
        <string>ko</string>
    </array>
</dict>
</plist>
